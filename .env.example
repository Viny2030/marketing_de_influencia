# ─────────────────────────────────────────────────────────
# .env.example — Copiar a .env y completar antes de levantar
# Nunca commitear el .env real al repositorio
# ─────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=marketing_db

# SQLAlchemy (construida automáticamente desde las vars de arriba en docker-compose)
# DATABASE_URL=postgresql://user:password@db:5432/marketing_db

# Presupuestos por canal (en USD)
BUDGET_YOUTUBE=1500
BUDGET_INSTAGRAM=800
BUDGET_GOOGLE_ADS=1200
BUDGET_FACEBOOK=900

# Scraper
SCRAPER_INTERVAL=3600        # segundos entre ciclos (default 1h)
ATTRIBUTION_WINDOW_HOURS=24  # ventana de atribución en horas
